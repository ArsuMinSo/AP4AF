@page "/student/menu"
@implements IDisposable
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Today's Menu</PageTitle>

<h1>Today's Menu</h1>

@if (menuItems == null)
{
    <p><em>Loading...</em></p>
}
else if (!menuItems.Any())
{
    <div class="alert alert-info">No menu items available today.</div>
}
else
{
    <div class="row">
        @foreach (var item in menuItems)
        {
            bool soldOut = item.AvailablePortions == 0;
            <div class="col-md-4 mb-3">
                <div class="card @(soldOut ? "border-secondary text-muted" : "")">
                    <div class="card-body">
                        <h5 class="card-title">@item.Food.Name</h5>
                        <p class="card-text">@item.Food.Description</p>
                        <p class="card-text">
                            <strong>@item.Food.Price.ToString("C")</strong>
                        </p>
                        @if (soldOut)
                        {
                            <span class="badge bg-secondary fs-6">Sold Out</span>
                        }
                        else
                        {
                            <p class="text-muted small">@item.AvailablePortions portions left</p>
                            <button class="btn btn-primary" @onclick="() => PlaceOrder(item.Id)" disabled="@orderInProgress">
                                Order
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (orders.Any())
{
    <h2 class="mt-4">My Orders</h2>
    <table class="table">
        <thead>
            <tr>
                <th>Food</th>
                <th>Ordered At</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in orders.OrderByDescending(o => o.CreatedAt))
            {
                <tr>
                    <td>@order.FoodName</td>
                    <td>@order.CreatedAt.ToLocalTime().ToShortTimeString()</td>
                    <td><span class="badge @GetStatusBadge(order.Status)">@order.Status</span></td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success") mt-3">@statusMessage</div>
}

@code {
    private List<MenuItemDto>? menuItems;
    private List<OrderDto> orders = [];
    private bool orderInProgress = false;
    private string statusMessage = string.Empty;
    private bool isError = false;
    private System.Net.Http.HttpClient? sseClient;
    private CancellationTokenSource? cts;

    protected override async Task OnInitializedAsync()
    {
        await LoadMenu();
        _ = Task.Run(ListenForSseUpdates);
    }

    private async Task LoadMenu()
    {
        var client = HttpClientFactory.CreateClient("WebApi");
        menuItems = await client.GetFromJsonAsync<List<MenuItemDto>>("/menu/today");
    }

    private async Task PlaceOrder(int menuItemId)
    {
        orderInProgress = true;
        statusMessage = string.Empty;
        var client = HttpClientFactory.CreateClient("WebApi");
        var response = await client.PostAsJsonAsync("/orders", new { MenuItemId = menuItemId });
        if (response.IsSuccessStatusCode)
        {
            var order = await response.Content.ReadFromJsonAsync<OrderDto>();
            if (order is not null) orders.Add(order);
            isError = false;
            statusMessage = "Order placed successfully!";
            await LoadMenu();
        }
        else
        {
            isError = true;
            statusMessage = await response.Content.ReadAsStringAsync();
        }
        orderInProgress = false;
    }

    private async Task ListenForSseUpdates()
    {
        try
        {
            cts = new CancellationTokenSource();
            sseClient = HttpClientFactory.CreateClient("WebApi");
            using var stream = await sseClient.GetStreamAsync("/orders/events", cts.Token);
            using var reader = new System.IO.StreamReader(stream);

            while (!cts.Token.IsCancellationRequested && !reader.EndOfStream)
            {
                var line = await reader.ReadLineAsync(cts.Token);
                if (line?.StartsWith("data:") == true)
                {
                    // Refresh orders display
                    await InvokeAsync(async () =>
                    {
                        await LoadMenu();
                        StateHasChanged();
                    });
                }
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception) { }
    }

    private static string GetStatusBadge(string status) => status switch
    {
        "Preparing" => "bg-warning text-dark",
        "Ready" => "bg-success",
        "Cancelled" => "bg-danger",
        "Completed" => "bg-primary",
        _ => "bg-secondary"
    };

    public void Dispose()
    {
        cts?.Cancel();
        cts?.Dispose();
        sseClient?.Dispose();
    }

    private record FoodDto(int Id, string Name, string Description, decimal Price, bool IsActive);
    private record MenuItemDto(int Id, DateOnly Date, FoodDto Food, int AvailablePortions);
    private record OrderDto(int Id, int MenuItemId, string FoodName, DateTime CreatedAt, string Status);
}
