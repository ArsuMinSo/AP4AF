@page "/"

<PageTitle>Canteen</PageTitle>

<h1>Canteen</h1>

<div class="row mt-3">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Student</h5>
                <p class="card-text">Order food from today's menu.</p>
                <a href="/student/menu" class="btn btn-primary">Order Food</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Kitchen Staff</h5>
                <p class="card-text">View and manage active orders.</p>
                <a href="/cook/orders" class="btn btn-warning">Manage Orders</a>
            </div>
        </div>
    </div>
</div>
