@page "/menu/create"
@page "/menu/{Id:int}/edit"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>@(Id == null ? "Add Menu Item" : "Edit Menu Item")</PageTitle>

<h1>@(Id == null ? "Add Menu Item" : "Edit Menu Item")</h1>

<div class="row">
    <div class="col-md-6">
        <EditForm Model="model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Date</label>
                <InputDate class="form-control" @bind-Value="model.Date" />
            </div>
            <div class="mb-3">
                <label class="form-label">Food</label>
                <InputSelect class="form-select" @bind-Value="model.FoodId">
                    <option value="0">-- Select Food --</option>
                    @if (foods != null)
                    {
                        @foreach (var food in foods.Where(f => f.IsActive))
                        {
                            <option value="@food.Id">@food.Name (@food.Price.ToString("C"))</option>
                        }
                    }
                </InputSelect>
            </div>
            <div class="mb-3">
                <label class="form-label">Available Portions</label>
                <InputNumber class="form-control" @bind-Value="model.AvailablePortions" />
            </div>

            <button type="submit" class="btn btn-primary">@(Id == null ? "Create" : "Save")</button>
            <a href="/menu" class="btn btn-secondary ms-2">Cancel</a>
        </EditForm>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@code {
    [Parameter] public int? Id { get; set; }

    private MenuItemModel model = new();
    private List<FoodDto>? foods;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("WebApi");
        foods = await client.GetFromJsonAsync<List<FoodDto>>("/foods");

        if (Id is not null)
        {
            var item = await client.GetFromJsonAsync<MenuItemDto>($"/menu/{Id}");
            if (item is not null)
            {
                model.Date = item.Date;
                model.FoodId = item.Food.Id;
                model.AvailablePortions = item.AvailablePortions;
            }
        }
        else
        {
            model.Date = DateOnly.FromDateTime(DateTime.Today);
        }
    }

    private async Task HandleSubmit()
    {
        errorMessage = string.Empty;
        if (model.FoodId == 0)
        {
            errorMessage = "Please select a food item.";
            return;
        }

        var client = HttpClientFactory.CreateClient("WebApi");
        HttpResponseMessage response;

        if (Id == null)
        {
            response = await client.PostAsJsonAsync("/menu", new { model.Date, FoodId = model.FoodId, model.AvailablePortions });
        }
        else
        {
            response = await client.PutAsJsonAsync($"/menu/{Id}", new { model.Date, FoodId = model.FoodId, model.AvailablePortions });
        }

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/menu");
        }
        else
        {
            errorMessage = $"Error: {response.StatusCode}";
        }
    }

    private class MenuItemModel
    {
        public DateOnly Date { get; set; }
        public int FoodId { get; set; }
        public int AvailablePortions { get; set; }
    }

    private record FoodDto(int Id, string Name, string Description, decimal Price, bool IsActive);
    private record MenuItemDto(int Id, DateOnly Date, FoodDto Food, int AvailablePortions);
}
