@page "/menu"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Menu</PageTitle>

<h1>Menu</h1>

@if (menuItems == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <a href="/menu/create" class="btn btn-success mb-3">Add Menu Item</a>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Food</th>
                <th>Price</th>
                <th>Available Portions</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in menuItems.OrderByDescending(m => m.Date))
            {
                <tr>
                    <td>@item.Date.ToShortDateString()</td>
                    <td>@item.Food.Name</td>
                    <td>@item.Food.Price.ToString("C")</td>
                    <td>
                        @if (item.AvailablePortions == 0)
                        {
                            <span class="badge bg-danger">Sold Out</span>
                        }
                        else
                        {
                            @item.AvailablePortions
                        }
                    </td>
                    <td>
                        <a href="/menu/@item.Id/edit" class="btn btn-sm btn-primary">Edit</a>
                        <button class="btn btn-sm btn-danger ms-1" @onclick="() => DeleteMenuItem(item.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info">@message</div>
}

@code {
    private List<MenuItemDto>? menuItems;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadMenu();
    }

    private async Task LoadMenu()
    {
        var client = HttpClientFactory.CreateClient("WebApi");
        menuItems = await client.GetFromJsonAsync<List<MenuItemDto>>("/menu");
    }

    private async Task DeleteMenuItem(int id)
    {
        var client = HttpClientFactory.CreateClient("WebApi");
        var response = await client.DeleteAsync($"/menu/{id}");
        if (response.IsSuccessStatusCode)
        {
            message = "Menu item deleted.";
            await LoadMenu();
        }
    }

    private record FoodDto(int Id, string Name, string Description, decimal Price, bool IsActive);
    private record MenuItemDto(int Id, DateOnly Date, FoodDto Food, int AvailablePortions);
}
